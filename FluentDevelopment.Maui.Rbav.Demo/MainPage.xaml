<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ext="clr-namespace:FluentDevelopment.Maui.Rbav.Extenations;assembly=FluentDevelopment.Maui.Rbav"
             x:Class="FluentDevelopment.Maui.Rbav.Demo.MainPage">
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                IsVisible="{ext:RoleToVisibility Role='admin'}"
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a hovercraft number nine" />

            <Label
                TextColor="Red"
                IsVisible="{ext:PermissionToVisibility admin.main.view}"
                Text="admin.main.view"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />
            <Label
                TextColor="Red"
                IsVisible="{ext:PermissionToVisibility user.main.view}"
                Text="user.main.view"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />
            <Label
                TextColor="Red"
                IsVisible="{ext:PermissionToVisibility main.view}"
                Text="main.view"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />
            <Label
                TextColor="Red"
                IsVisible="{ext:PermissionToVisibility Permission='user'}"
                Text="user"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />
            <Label
                Text="Welcome to &#10;.NET Multi-platform App UI"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />
            <Picker x:Name="pPerm" Title="Permissions" ItemDisplayBinding="{Binding Name}"/>
            <Button Text="remove Permission" Clicked="Button_Clicked_2"/>

            <Button 
                Text="logout"
                Clicked="OnLogoutClicked"
                HorizontalOptions="Fill" />
        </VerticalStackLayout>
    </ScrollView>


</ContentPage>
