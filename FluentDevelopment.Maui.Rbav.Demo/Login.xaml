<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FluentDevelopment.Maui.Rbav.Demo.Login"
             Title="Login">
    <VerticalStackLayout>

        <Picker x:Name="picker" Title="Picker Username" SelectedItem="admin">
            <Picker.Items>
                <x:String>admin</x:String>
                <x:String>user</x:String>
                <x:String>guest</x:String>
            </Picker.Items>
        </Picker>
        <Button Text="login" Clicked="Button_Clicked"/>
    </VerticalStackLayout>
</ContentPage>